<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_magento" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.magento</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='home_finance_settings']" position="after">
                <block title="Magento Integration" name="magento_integration_settings">
                    <setting string="Magento Base URL">
                        <field name="magento_base_url" placeholder="http://mystore.com"/>
                    </setting>
                    <setting string="Magento API Token">
                        <field name="magento_api_token" password="True"/>
                    </setting>
                    <setting string="Timeout">
                        <field name="magento_timeout"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>