<?xml version="1.0"?>
<odoo>
    <!-- Transaction views    -->
    <record id="hf_transaction_action" model="ir.actions.act_window">
        <field name="name">Transactions</field>
        <field name="res_model">home_finance.transaction</field>
        <field name="view_mode">list,form,pivot</field>
    </record>
    <record id="hf_transaction_income_action" model="ir.actions.act_window">
        <field name="name">Income Transactions</field>
        <field name="res_model">home_finance.transaction</field>
        <field name="view_mode">list</field>
        <field name="domain">['&amp;',('wallet_id', '=', active_id),('type', '=', 'income')]</field>
    </record>
    <record id="hf_transaction_expense_action" model="ir.actions.act_window">
        <field name="name">Expense Transactions</field>
        <field name="res_model">home_finance.transaction</field>
        <field name="view_mode">list</field>
        <field name="domain">['&amp;',('wallet_id', '=', active_id),('type', '=', 'expense')]</field>
    </record>
    <record id="hf_transaction_view_form" model="ir.ui.view">
        <field name="name">home_finance.transaction.view.form</field>
        <field name="model">home_finance.transaction</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="period"/>
                            <field name="type"/>
                            <field name="wallet_id"/>
                            <field name="category_id"/>
                        </group>
                        <group>
                            <field name="project_id" invisible="type=='expense'"/>
                            <field name="amount"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="comment" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="hf_transaction_view_list" model="ir.ui.view">
        <field name="name">home_finance.transaction.view.list</field>
        <field name="model">home_finance.transaction</field>
        <field name="arch" type="xml">
            <list decoration-danger="type == 'expense'"
                  decoration-success="type == 'income'" edit="1">
                <field name="period"/>
                <field name="type"/>
                <field name="wallet_id"/>
                <field name="category_id"/>
                <field name="currency_id"/>
                <field name="amount"/>
                <field name="project_id"/>
                <field name="comment" optional="hide"/>
                <field name="create_date" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="hf_transaction_view_pivot" model="ir.ui.view">
        <field name="name">home_finance.transaction.view.pivot</field>
        <field name="model">home_finance.transaction</field>
        <field name="arch" type="xml">
            <pivot>
                <!--                <field name="period" type="column"/>-->
                <field name="project_id" type="column"/>
                <field name="category_id" type="row"/>
                <field name="base_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="hf_transaction_view_filter" model="ir.ui.view">
        <field name="name">home_finance.transaction.view.filter</field>
        <field name="model">home_finance.transaction</field>
        <field name="arch" type="xml">
            <search string="Transactions">
                <field name="period"/>
                <field name="type"/>
                <field name="wallet_id"/>
                <field name="category_id"/>
                <field name="project_id"/>
                <group>
                    <filter name="period" context="{'group_by': 'period'}"/>
                    <filter name="currency_id" context="{'group_by': 'currency_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Transfer views    -->
    <record id="hf_transfer_action" model="ir.actions.act_window">
        <field name="name">Transfers</field>
        <field name="res_model">home_finance.transfer</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="hf_transfer_in_action" model="ir.actions.act_window">
        <field name="name">Transfers In</field>
        <field name="res_model">home_finance.transfer</field>
        <field name="view_mode">list</field>
        <field name="domain">[('destination_wallet_id', '=', active_id)]</field>
    </record>
    <record id="hf_transfer_out_action" model="ir.actions.act_window">
        <field name="name">Transfers In</field>
        <field name="res_model">home_finance.transfer</field>
        <field name="view_mode">list</field>
        <field name="domain">[('source_wallet_id', '=', active_id)]</field>
    </record>
    <record id="hf_transfer_view_form" model="ir.ui.view">
        <field name="name">home_finance.transfer.view.form</field>
        <field name="model">home_finance.transfer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="period"/>
                        <group string="From">
                            <field name="source_wallet_id"/>
                            <field name="source_amount"/>
                            <field name="source_currency_id"/>
                        </group>
                        <group string="To">
                            <field name="destination_wallet_id"/>
                            <field name="destination_amount"/>
                            <field name="destination_currency_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="comment" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="hf_transfer_view_filter" model="ir.ui.view">
        <field name="name">home_finance.transfer.view.filter</field>
        <field name="model">home_finance.transfer</field>
        <field name="arch" type="xml">
            <search string="Transfer">
                <field name="period"/>
                <group>
                    <filter name="period" context="{'group_by': 'period'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="hf_transfer_view_list" model="ir.ui.view">
        <field name="name">home_finance.transfer.view.list</field>
        <field name="model">home_finance.transfer</field>
        <field name="arch" type="xml">
            <list>
                <field name="period"/>
                <field name="source_wallet_id"/>
                <field name="source_amount"/>
                <field name="source_currency_id"/>
                <field name="destination_wallet_id"/>
                <field name="destination_amount"/>
                <field name="destination_currency_id"/>
                <field name="comment" optional="hide"/>
                <field name="create_date" optional="hide"/>
            </list>
        </field>
    </record>
    <!-- Wallet views    -->
    <record id="hf_wallet_action" model="ir.actions.act_window">
        <field name="name">Wallets</field>
        <field name="res_model">home_finance.wallet</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="hf_wallet_view_list" model="ir.ui.view">
        <field name="name">home_finance.wallet.view.list</field>
        <field name="model">home_finance.wallet</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type"/>
            </list>
        </field>
    </record>

    <record id="hf_wallet_view_form" model="ir.ui.view">
        <field name="name">home_finance.wallet.view.form</field>
        <field name="model">home_finance.wallet</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                                name="%(hf_transaction_income_action)d"
                                type="action"
                                icon="fa-file-text-o"
                                help="Wallet Income Transactions">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value d-flex gap-1">
                                    <field name="income_amount" widget="statinfo" class="oe_inline"/>
                                </span>
                            </div>
                        </button>
                        <button class="oe_stat_button"
                                name="%(hf_transaction_expense_action)d"
                                type="action"
                                icon="fa-file-text-o"
                                help="Wallet Expense Transactions">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value d-flex gap-1">
                                    <field name="expense_amount" widget="statinfo" class="oe_inline"/>
                                </span>
                            </div>
                        </button>
                        <button class="oe_stat_button"
                                name="%(hf_transfer_in_action)d"
                                type="action"
                                icon="fa-file-text-o"
                                help="Wallet In Transfers">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value d-flex gap-1">
                                    <field name="transfer_in_amount" widget="statinfo" class="oe_inline"/>
                                </span>
                            </div>
                        </button>
                        <button class="oe_stat_button"
                                name="%(hf_transfer_out_action)d"
                                type="action"
                                icon="fa-file-text-o"
                                help="Wallet Out Transfers">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value d-flex gap-1">
                                    <field name="transfer_out_amount" widget="statinfo" class="oe_inline"/>
                                </span>
                            </div>
                        </button>
                    </div>

                    <group>
                        <field name="name"/>
                        <field name="type"/>
                        <field name="currency_id"/>
                        <field name="bank_id"/>
                        <field name="user_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Category views    -->
    <record id="hf_category_action" model="ir.actions.act_window">
        <field name="name">Transaction Categories</field>
        <field name="res_model">home_finance.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Project views    -->
    <record id="hf_project_action" model="ir.actions.act_window">
        <field name="name">Transaction Projects</field>
        <field name="res_model">home_finance.project</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Statement Import views    -->
    <record id="hf_statement_import_action" model="ir.actions.act_window">
        <field name="name">Import Bank Statement</field>
        <field name="res_model">home_finance.statement.import</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="hf_statement_import_view_form" model="ir.ui.view">
        <field name="name">home_finance.statement.import.view.form</field>
        <field name="model">home_finance.statement.import</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="period"/>
                        <field name="wallet_id"/>
                        <field name="import_rule_id"/>
                    </group>
                    <group>
                        <field name="file" filename="filename" widget="binary" accept=".xlsx,.xls,.csv"/>
                    </group>

                    <group>
                        <button name="action_parse" type="object" string="Parse File" class="btn-primary"/>
                        <button name="action_convert" type="object" string="Convert Lines Into Documents"
                                class="btn-primary"/>
                    </group>
                    <notebook>
                        <page string="Import Lines">
                            <field name="line_ids" widget="one2many" mode="list"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="hf_statement_import_view_list" model="ir.ui.view">
        <field name="name">home_finance.statement.import.view.list</field>
        <field name="model">home_finance.statement.import</field>
        <field name="arch" type="xml">
            <list>
                <field name="period"/>
                <field name="wallet_id"/>
            </list>
        </field>
    </record>
    <record id="hf_statement_import_line_view_list" model="ir.ui.view">
        <field name="name">home_finance.statement.import.line.view.list</field>
        <field name="model">home_finance.statement.import.line</field>
        <field name="arch" type="xml">
            <list editable="top" decoration-success="status == 'converted'" decoration-danger="status == 'error'">
                <field name="display_line_no"/>
                <button name="action_set_draft" type="object" icon="fa-check" title="Mark as Fixed"
                        invisible="status != 'error'"/>
                <field name="type"/>
                <field name="wallet_id"/>
                <field name="category_id"/>
                <field name="project_id"/>
                <field name="amount"/>
                <field name="destination_wallet_id"/>
                <field name="destination_amount" optional="hide"/>
                <field name="destination_currency_id" optional="hide"/>
                <field name="comment" optional="hide"/>
                <field name="statement_purpose" optional="hide"/>
                <field name="status" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Statement Import Rule views    -->
    <record id="hf_statement_import_rule_action" model="ir.actions.act_window">
        <field name="name">Statement Import Rules</field>
        <field name="res_model">home_finance.statement.import.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="hf_statement_import_rule_view_form" model="ir.ui.view">
        <field name="name">home_finance.statement.import.rule.view.form</field>
        <field name="model">home_finance.statement.import.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="General">
                        <field name="wallet_id"/>
                        <field name="file_type"/>
                        <field name="active"/>
                    </group>
                    <group string="Statement Columns Mapping">
                        <field name="statement_purpose_column"/>
                        <field name="statement_commentary_column"/>
                        <field name="statement_amount_column"/>
                        <field name="statement_first_row"/>
                    </group>
                    <notebook>
                        <page string="Import Rules">
                            <field name="rule_line_ids" widget="one2many" mode="list"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="hf_statement_import_rule_view_list" model="ir.ui.view">
        <field name="name">home_finance.statement.import.rule.view.list</field>
        <field name="model">home_finance.statement.import.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="wallet_id"/>
                <field name="file_type"/>
            </list>
        </field>
    </record>
    <record id="hf_statement_import_rule_line_view_list" model="ir.ui.view">
        <field name="name">home_finance.statement.import.rule.line.view.list</field>
        <field name="model">home_finance.statement.import.rule.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="type"/>
                <field name="purpose_key_word"/>
                <field name="commentary_key_word"/>
                <field name="category_id" invisible="type=='transfer'"/>
                <field name="wallet_id" invisible="type!='transfer'"/>
                <field name="sequence" widget="handle"/>
            </list>
        </field>
    </record>
    <record id="hf_statement_import_rule_line_view_form" model="ir.ui.view">
        <field name="name">home_finance.statement.import.rule.line.view.form</field>
        <field name="model">home_finance.statement.import.rule.line</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_save_and_duplicate"
                            type="object"
                            string="Save and Duplicate"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="rule_id" invisible="1"/>
                        <field name="type"/>
                        <field name="purpose_key_word"/>
                        <field name="commentary_key_word"/>
                        <field name="category_id" invisible="type=='transfer'"/>
                        <field name="wallet_id" invisible="type!='transfer'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Balance views    -->
    <record id="hf_wallet_balance_action" model="ir.actions.act_window">
        <field name="name">Balance</field>
        <field name="res_model">home_finance.wallet.balance</field>
        <field name="view_mode">list,pivot</field>
    </record>
    <record id="hf_wallet_balance_view_list" model="ir.ui.view">
        <field name="name">home_finance.wallet.balance.view.list</field>
        <field name="model">home_finance.wallet.balance</field>
        <field name="arch" type="xml">
            <list edit="0" create="0" delete="0" decoration-danger="amount &lt; 0">
                <field name="period"/>
                <field name="wallet_id"/>
                <field name="currency_id"/>
                <field name="amount"/>
            </list>
        </field>
    </record>
    <record id="hf_wallet_balance_view_pivot" model="ir.ui.view">
        <field name="name">home_finance.wallet.balance.view.pivot</field>
        <field name="model">home_finance.wallet.balance</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="currency_id" type="column"/>
                <field name="wallet_id" type="row"/>
                <field name="amount" type="measure"/>
                <field name="base_amount" type="measure"/>
            </pivot>
        </field>
    </record>
</odoo>
