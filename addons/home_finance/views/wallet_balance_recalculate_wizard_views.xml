<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hf_wallet_balance_recalculate_wizard_action" model="ir.actions.act_window">
        <field name="name">Recalculate Wallet Balances</field>
        <field name="res_model">home_finance.wallet.balance.recalculate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <!-- Wizard form view -->
    <record id="hf_wallet_balance_recalculate_wizard_view_form" model="ir.ui.view">
        <field name="name">home_finance.wallet.balance.recalculate.wizard.form</field>
        <field name="model">home_finance.wallet.balance.recalculate.wizard</field>
        <field name="arch" type="xml">
            <form string="Recalculate Wallet Balances">
                <group>
                    <field name="note" nolabel="1" readonly="1"/>
                </group>
                <footer>
                    <button name="action_calculate"
                            type="object"
                            string="Calculate"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>