<odoo>
    <record id="hf_view_settings" model="ir.ui.view">
        <field name="name">home.finance.settings.view</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='general_settings']/block[1]" position="before">
                <block title="Home Finance" name="home_finance_settings">
                    <setting string="Current Period">
                        <field name="home_finance_current_period"/>
                    </setting>
                    <setting string="Statement Import TTL">
                        <field name="home_finance_statement_import_ttl"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>