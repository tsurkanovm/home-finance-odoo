<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="home_finance.Dashboard">
        <div class="hf-dashboard o_view_controller">
            <t t-if="state.loading">
                <div class="hf-dashboard__loading">
                    <i class="fa fa-spinner fa-spin fa-2x" />
                    <span t-esc="_t('Loading dashboard...')" />
                </div>
            </t>
            <t t-else="">
                <div class="hf-dashboard__header">
                    <h2 t-esc="_t('Home Finance Dashboard')" />
                    <span t-if="state.currentPeriod" class="hf-dashboard__period">
                        <t t-esc="_t('Period:')" /> <strong t-esc="state.currentPeriod" />
                    </span>
                    <div class="hf-dashboard__currency-switcher">
                        <t t-foreach="currencyOptions" t-as="cur" t-key="cur">
                            <button
                                t-attf-class="btn btn-sm {{ state.selectedCurrency === cur ? 'btn-secondary' : 'btn-outline-secondary' }}"
                                t-on-click="() => this.setCurrency(cur)"
                                t-esc="cur"
                            />
                        </t>
                    </div>
                </div>

                <div class="hf-dashboard__cards">
                    <StatCard
                        title="_t('Total Balance')"
                        value="balanceSummary"
                        icon="'wallet'"
                        variant="'primary'"
                    />
                    <StatCard
                        title="_t('Expenses')"
                        value="formattedExpense"
                        subtitle="_t('Current period')"
                        icon="'arrow-down'"
                        variant="'danger'"
                    />
                    <StatCard
                        title="_t('Income')"
                        value="formattedIncome"
                        subtitle="_t('Current period')"
                        icon="'arrow-up'"
                        variant="'success'"
                    />
                    <StatCard
                        title="_t('Top Category')"
                        value="topCategoryName"
                        subtitle="_t('Highest expense')"
                        icon="'tag'"
                        variant="'warning'"
                    />
                </div>

                <div class="hf-dashboard__chart-section">
                    <div class="hf-dashboard__chart-header">
                        <h3 t-esc="_t('Expense Trend')" />
                        <div class="hf-dashboard__filters">
                            <t t-foreach="[3, 6, 12]" t-as="months" t-key="months">
                                <button
                                    t-attf-class="btn btn-sm {{ state.filterMonths === months ? 'btn-primary' : 'btn-outline-primary' }}"
                                    t-on-click="() => this.setFilter(months)"
                                    t-esc="`${months} ${_t('months')}`"
                                />
                            </t>
                        </div>
                    </div>
                    <ExpenseChart data="chartData" />
                </div>

                <div t-if="state.topCategories.length" class="hf-dashboard__categories">
                    <h3 t-esc="_t('Top Expense Categories (Current Period)')" />
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th t-esc="_t('Category')" />
                                <th class="text-end" t-esc="_t('Amount')" />
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="formattedCategories" t-as="cat" t-key="cat_index">
                                <tr>
                                    <td t-esc="cat.name" />
                                    <td class="text-end" t-esc="cat.amount" />
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </div>
    </t>
</templates>
