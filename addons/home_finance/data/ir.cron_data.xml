<odoo noupdate="1">
    <record id="ir_cron_statement_import_cleanup" model="ir.cron">
        <field name="name">Home Finance: Cleanup Expired Statement Imports</field>
        <field name="model_id" ref="model_home_finance_statement_import"/>
        <field name="state">code</field>
        <field name="code">model.cron_cleanup_expired_imports()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="nextcall"
               eval="(datetime.now() + relativedelta(months=1, day=1, hour=3, minute=0, second=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="active">True</field>
    </record>
</odoo>