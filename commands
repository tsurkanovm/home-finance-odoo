#DB initialization:
docker compose --env-file env.local run --rm --entrypoint /usr/bin/odoo web \
  --config /etc/odoo/odoo.conf \
  -d home_finance \
  -i base \
  --without-demo=all \
  --stop-after-init

docker compose --env-file env.local down -v
