#DB initialization:
docker compose --env-file env.local run --rm --entrypoint /usr/bin/odoo web \
  --config /etc/odoo/odoo.conf \
  -d home_finance \
  -i base \
  --without-demo=all \
  --stop-after-init

docker compose --env-file env.local down -v
docker compose --env-file env.local up -d

docker compose --env-file env.local logs -f web
#restart web container
docker compose --env-file env.local restart web

docker compose exec web bash
odoo -d odoof -u ud_estate --stop-after-init  # inside the container

#restart and update module:
docker compose --env-file env.local run --rm --entrypoint /usr/bin/odoo web --config /etc/odoo/odoo.conf -d home_finance -u home_finance --without-demo --stop-after-init

#restart and update multiple modules (comma-separated, no spaces):
docker compose --env-file env.local run --rm --entrypoint /usr/bin/odoo web --config /etc/odoo/odoo.conf -d home_finance -u home_finance,nbu_currency_rate --without-demo --stop-after-init && docker compose --env-file env.local restart web

#setup demo data (if demo data changes needs to drop demo DB)
docker compose run --rm --entrypoint /usr/bin/odoo web --config /etc/odoo/odoo.conf -d odoof_demo -i ud_estate --with-demo --stop-after-init

# db dump
docker compose exec db pg_dump -U odoo -Fc home_finance > hf_2026-03-31.dump

#db restore
 docker compose exec -T db pg_restore -U odoo -d home_finance < hf_2026-03-31.dump

